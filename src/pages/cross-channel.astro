---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import MetricCard from '../components/ui/MetricCard.astro';
import ChartContainer from '../components/charts/ChartContainer.astro';
import { getConnector } from '../connectors/registry';
import { formatNumber, formatPercent } from '../utils/formatters';
import DataSourceTag from '../components/ui/DataSourceTag.astro';
import { buildSankeyData, buildCrossChannelSummary } from '../utils/sankey-transformer';

import { getDefaultDateRange } from '../utils/date-range';
const dateRange = getDefaultDateRange('30d');

const [webResult, crmResult] = await Promise.all([
  getConnector('web').fetch(dateRange),
  getConnector('crm').fetch(dateRange),
]);

const web = webResult.data;
const crm = crmResult.data;

const sankeyData = buildSankeyData(web, crm);
const summary = buildCrossChannelSummary(web, crm);
const sankeyJson = JSON.stringify(sankeyData);

// Source tag: show "mixed" when combining GA4 + CRM
const combinedSource = webResult.source === 'live' && crmResult.source === 'live' ? 'live' : 'mock';

// Channel attribution table with conversion rates
const channelTable = crm.channelAttribution.map(ch => {
  const mixKey = Object.entries({
    organic: 'Organic Search', direct: 'Direct', social: 'Social Media',
    email: 'Email', paid: 'Paid Search', referral: 'Referral',
  }).find(([, name]) => name === ch.channel)?.[0];

  const pct = mixKey ? (web.channelMix as Record<string, number>)[mixKey] ?? 0 : 0;
  const sessions = Math.round(web.sessions * pct / 100);
  const convRate = sessions > 0 ? (ch.leads / sessions) * 100 : 0;

  return { ...ch, sessions, convRate };
});
---

<DashboardLayout title="Channel Flow" activeNav="cross-channel">
  <!-- KPI Cards -->
  <section class="grid-kpi">
    <MetricCard
      title="Total Sessions"
      value={formatNumber(summary.totalSessions)}
      source={webResult.source}
      sourceName="GA4"
    />
    <MetricCard
      title="Total Leads"
      value={formatNumber(summary.totalLeads)}
      source={crmResult.source}
      sourceName="HubSpot"
    />
    <MetricCard
      title="Session → Lead"
      value={formatPercent(summary.overallConversionRate)}
      source={combinedSource}
      sourceName="GA4 + HubSpot"
    />
    <MetricCard
      title="Top Channel"
      value={summary.topChannel.name}
      tooltip={`${formatNumber(summary.topChannel.sessions)} sessions`}
      source={webResult.source}
      sourceName="GA4"
    />
    {summary.bestConvertingChannel && (
      <MetricCard
        title="Best Converter"
        value={summary.bestConvertingChannel.name}
        delta={Number(summary.bestConvertingChannel.rate.toFixed(1))}
        deltaLabel="conv. rate"
        source={combinedSource}
        sourceName="GA4 + HubSpot"
      />
    )}
    <MetricCard
      title="Deals Won"
      value={formatNumber(summary.totalWon)}
      delta={Number(summary.winRate.toFixed(1))}
      deltaLabel="win rate"
      source={crmResult.source}
      sourceName="HubSpot"
    />
  </section>

  <!-- Sankey Chart -->
  <section class="grid-charts">
    <ChartContainer
      title="Cross-Channel Attribution Flow"
      subtitle="Channel → Sessions → Leads → MQL → SQL → Pipeline → Won"
      source={combinedSource}
      sourceName="GA4 + HubSpot"
      id="sankey-chart"
      height="480px"
    />
  </section>

  <!-- Channel Attribution Table -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Channel Performance</h3>
      <DataSourceTag source={combinedSource} name="GA4 + HubSpot" />
    </div>
    <div class="table-wrapper">
      <table class="data-table" data-csv-export="channel-performance">
        <thead>
          <tr>
            <th>Channel</th>
            <th class="num">Sessions</th>
            <th class="num">Leads</th>
            <th class="num">Conv. Rate</th>
            <th class="num">MQL</th>
            <th class="num">SQL</th>
            <th class="num">Won</th>
            <th class="num">CAC</th>
          </tr>
        </thead>
        <tbody>
          {channelTable.map((ch) => (
            <tr>
              <td class="channel-name">{ch.channel}</td>
              <td class="num">{formatNumber(ch.sessions)}</td>
              <td class="num">{formatNumber(ch.leads)}</td>
              <td class="num">{formatPercent(ch.convRate)}</td>
              <td class="num">{formatNumber(ch.mql)}</td>
              <td class="num">{formatNumber(ch.sql)}</td>
              <td class="num">{formatNumber(ch.won)}</td>
              <td class="num">${formatNumber(ch.cac)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>

<style>
  .grid-kpi { margin-bottom: var(--space-6); }
  .grid-charts { margin-bottom: var(--space-6); }

  .table-section {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .table-header { display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--border-default); }
  .table-title { font-size: var(--text-sm); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .table-wrapper { overflow-x: auto; }
  .data-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .data-table th { text-align: left; padding: var(--space-3) var(--space-5); font-size: var(--text-xs); font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid var(--border-default); }
  .data-table td { padding: var(--space-3) var(--space-5); color: var(--text-secondary); border-bottom: 1px solid var(--surface-2); }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--surface-2); }
  .num { text-align: right; font-variant-numeric: tabular-nums; }
  .channel-name { font-weight: 500; color: var(--text-primary); }
</style>

<script define:vars={{ sankeyJson }}>
  window.__sankey_data = JSON.parse(sankeyJson);
</script>

<script>
  import echarts from '../utils/echarts-setup';
  import { dashboardTheme } from '../utils/echarts-theme';

  echarts.registerTheme('dashboard', dashboardTheme);

  const el = document.getElementById('sankey-chart');
  if (el) {
    const chart = echarts.init(el, 'dashboard');
    const data = (window as any).__sankey_data || { nodes: [], links: [] };

    const channelColors: Record<string, string> = {
      'Organic Search': '#818cf8',
      'Direct': '#06b6d4',
      'Social Media': '#f59e0b',
      'Email': '#10b981',
      'Paid Search': '#ef4444',
      'Referral': '#8b5cf6',
    };

    chart.setOption({
      tooltip: {
        trigger: 'item',
        formatter: (params: any) => {
          if (params.dataType === 'edge') {
            return `${params.data.source} → ${params.data.target}<br/><strong>${params.data.value.toLocaleString()}</strong>`;
          }
          return `<strong>${params.name}</strong>`;
        },
      },
      series: [{
        type: 'sankey',
        layout: 'none',
        emphasis: { focus: 'adjacency' },
        nodeAlign: 'left',
        data: data.nodes.map((n: any) => ({
          name: n.name,
          itemStyle: {
            color: channelColors[n.name]
              || (n.name.startsWith('Lost') || n.name === 'Bounced / No Conversion' ? '#475569' : undefined),
          },
        })),
        links: data.links,
        lineStyle: {
          color: 'gradient',
          opacity: 0.35,
        },
        label: {
          color: 'var(--text-primary)',
          fontSize: 11,
          fontFamily: 'Inter, sans-serif',
        },
        nodeWidth: 20,
        nodeGap: 12,
        left: '2%',
        right: '12%',
        top: '5%',
        bottom: '5%',
      }],
    });

    window.addEventListener('resize', () => chart.resize());

    // Theme change support
    document.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('#theme-toggle')) {
        setTimeout(() => chart.resize(), 100);
      }
    });
  }
</script>
