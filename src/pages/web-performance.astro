---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import MetricCard from '../components/ui/MetricCard.astro';
import ChartContainer from '../components/charts/ChartContainer.astro';
import { getConnector } from '../connectors/registry';
import { formatNumber, formatPercent, formatDuration, calcDelta } from '../utils/formatters';
import DataSourceTag from '../components/ui/DataSourceTag.astro';

import { getDefaultDateRange } from '../utils/date-range';
const dateRange = getDefaultDateRange('30d');

const webResult = await getConnector('web').fetch(dateRange);
const web = webResult.data;

const bounceRate = web.bounceRate;

// Device performance
const deviceBreakdown = web.deviceBreakdown;

// Traffic sparklines
const sessionSparkline = web.trafficByDay.slice(-14).map(d => d.sessions);
const userSparkline = web.trafficByDay.slice(-14).map(d => d.users);

const fmt = (v: number | null) => v !== null ? Number(v.toFixed(1)) : undefined;
const sessionsDelta = fmt(calcDelta(web.trafficByDay.map(d => d.sessions)));
const usersDelta = fmt(calcDelta(web.trafficByDay.map(d => d.users)));
const pageviewsDelta = fmt(calcDelta(web.trafficByDay.map(d => d.sessions * 2.5)));

// Serialize for client
const trafficData = JSON.stringify(web.trafficByDay);
const deviceData = JSON.stringify(deviceBreakdown);
---

<DashboardLayout title="Web Performance" activeNav="web-performance">
  <!-- KPI Cards -->
  <section class="grid-kpi">
    <MetricCard
      title="Sessions"
      value={formatNumber(web.sessions)}
      delta={sessionsDelta}
      source={webResult.source}
      sourceName="GA4"
      sparklineData={sessionSparkline}
    />
    <MetricCard
      title="Users"
      value={formatNumber(web.users)}
      delta={usersDelta}
      source={webResult.source}
      sourceName="GA4"
      sparklineData={userSparkline}
    />
    <MetricCard
      title="Pageviews"
      value={formatNumber(web.pageviews)}
      delta={pageviewsDelta}
      source={webResult.source}
      sourceName="GA4"
    />
    <MetricCard
      title="Bounce Rate"
      value={formatPercent(bounceRate)}
      delta={Number((45 - bounceRate).toFixed(1))}
      deltaLabel="vs benchmark 45%"
      source={webResult.source}
      sourceName="GA4"
    />
    <MetricCard
      title="Avg Session Duration"
      value={formatDuration(web.avgSessionDuration)}
      source={webResult.source}
      sourceName="GA4"
    />
    <MetricCard
      title="Conversion Rate"
      value={formatPercent(web.conversionRate)}
      source={webResult.source}
      sourceName="GA4"
    />
  </section>

  <!-- Charts -->
  <section class="grid-charts">
    <ChartContainer
      title="Traffic Trend"
      subtitle="Sessions & Users — last 90 days"
      source={webResult.source}
      sourceName="GA4"
      id="wp-traffic-chart"
      height="320px"
    />
    <ChartContainer
      title="Device Breakdown"
      subtitle="Sessions by device category"
      source={webResult.source}
      sourceName="GA4"
      id="wp-device-chart"
      height="320px"
    />
  </section>

  <!-- Top Pages Table -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Top Pages</h3>
      <DataSourceTag source={webResult.source} name="GA4" />
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Page</th>
            <th class="num">Views</th>
            <th class="num">Avg Time</th>
          </tr>
        </thead>
        <tbody>
          {web.topPages.map((page, i) => (
            <tr>
              <td class="page-path">
                <span class="rank">{i + 1}</span>
                {page.path}
              </td>
              <td class="num">{formatNumber(page.views)}</td>
              <td class="num">{formatDuration(page.avgTime)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>

<style>
  .grid-kpi { margin-bottom: var(--space-6); }
  .grid-charts { margin-bottom: var(--space-6); }

  .table-section {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .table-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-default);
  }

  .table-title {
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .table-wrapper { overflow-x: auto; }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .data-table th {
    text-align: left;
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border-default);
  }

  .data-table td {
    padding: var(--space-3) var(--space-5);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--surface-2);
  }

  .data-table tr:last-child td { border-bottom: none; }

  .data-table tr:hover td { background: var(--surface-2); }

  .num { text-align: right; font-variant-numeric: tabular-nums; }

  .page-path {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-primary);
  }

  .rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-sm);
    background: var(--surface-3);
    color: var(--text-muted);
    font-size: 10px;
    font-weight: 600;
    margin-right: var(--space-2);
    font-family: var(--font-body);
  }
</style>

<script define:vars={{ trafficData, deviceData }}>
  window.__wp_traffic = JSON.parse(trafficData);
  window.__wp_device = JSON.parse(deviceData);
</script>

<script>
  import echarts from '../utils/echarts-setup';
  import { dashboardTheme } from '../utils/echarts-theme';

  echarts.registerTheme('dashboard', dashboardTheme);

  // Traffic Trend
  const trafficEl = document.getElementById('wp-traffic-chart');
  if (trafficEl) {
    const chart = echarts.init(trafficEl, 'dashboard');
    const data = (window as any).__wp_traffic || [];

    chart.setOption({
      tooltip: { trigger: 'axis' },
      legend: { data: ['Sessions', 'Users'], right: 10, top: 0 },
      xAxis: {
        type: 'category',
        data: data.map((d: any) => d.date),
        axisLabel: {
          formatter: (val: string) => {
            const d = new Date(val);
            return `${d.getMonth() + 1}/${d.getDate()}`;
          },
          interval: 13,
        },
      },
      yAxis: { type: 'value' },
      series: [
        {
          name: 'Sessions',
          type: 'line',
          data: data.map((d: any) => d.sessions),
          smooth: true,
          lineStyle: { width: 2 },
          areaStyle: { opacity: 0.08 },
          symbolSize: 0,
        },
        {
          name: 'Users',
          type: 'line',
          data: data.map((d: any) => d.users),
          smooth: true,
          lineStyle: { width: 2 },
          areaStyle: { opacity: 0.08 },
          symbolSize: 0,
        },
      ],
    });
    window.addEventListener('resize', () => chart.resize());
  }

  // Device Breakdown
  const deviceEl = document.getElementById('wp-device-chart');
  if (deviceEl) {
    const chart = echarts.init(deviceEl, 'dashboard');
    const device = (window as any).__wp_device || {};

    chart.setOption({
      tooltip: { trigger: 'item', formatter: '{b}: {d}%' },
      series: [{
        type: 'pie',
        radius: ['45%', '70%'],
        center: ['50%', '55%'],
        avoidLabelOverlap: true,
        itemStyle: { borderRadius: 3, borderColor: '#111118', borderWidth: 2 },
        label: { color: '#8892a8', fontSize: 11, alignTo: 'edge', edgeDistance: 10 },
        labelLine: { length: 15, length2: 10 },
        labelLayout: { hideOverlap: true },
        data: [
          { value: device.desktop || 0, name: 'Desktop' },
          { value: device.mobile || 0, name: 'Mobile' },
          { value: device.tablet || 0, name: 'Tablet' },
        ],
      }],
    });
    window.addEventListener('resize', () => chart.resize());
  }
</script>
