---
import ChartContainer from '../components/charts/ChartContainer.astro';
import DataSourceTag from '../components/ui/DataSourceTag.astro';
import MetricCard from '../components/ui/MetricCard.astro';
import { getConnector } from '../connectors/registry';
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { formatNumber, formatPercent } from '../utils/formatters';

import { getDefaultDateRange } from '../utils/date-range';
const dateRange = getDefaultDateRange('30d');

const socialResult = await getConnector('social').fetch(dateRange);
const social = socialResult.data;

// Aggregate totals
const totalFollowers = social.platforms.reduce((a, p) => a + p.followers, 0);
const avgEngagement =
  social.platforms.reduce((a, p) => a + p.engagementRate, 0) / social.platforms.length;
const totalReferral = social.platforms.reduce((a, p) => a + p.referralTraffic, 0);

// Serialize for client
const platformsData = JSON.stringify(social.platforms);
const referralData = JSON.stringify(social.referralByDay);
---

<DashboardLayout title="Social Media" activeNav="social">
  <!-- KPI Cards -->
  <section class="grid-kpi">
    <MetricCard
      title="Total Followers"
      value={formatNumber(totalFollowers)}
      source={socialResult.source}
      sourceName="Social"
    />
    <MetricCard
      title="Avg Engagement Rate"
      value={formatPercent(avgEngagement)}
      source={socialResult.source}
      sourceName="Social"
    />
    <MetricCard
      title="Referral Traffic"
      value={formatNumber(totalReferral)}
      source={socialResult.source}
      sourceName="Social"
    />
    <MetricCard
      title="Platforms Tracked"
      value={String(social.platforms.length)}
      source={socialResult.source}
      sourceName="Social"
    />
  </section>

  <!-- Charts -->
  <section class="grid-charts">
    <ChartContainer
      title="Followers by Platform"
      subtitle="Current follower count & growth"
      source={socialResult.source}
      sourceName="Social"
      id="social-followers-chart"
      height="320px"
    />
    <ChartContainer
      title="Referral Traffic"
      subtitle="Sessions from social by platform — last 30 days"
      source={socialResult.source}
      sourceName="Social"
      id="social-referral-chart"
      height="320px"
    />
  </section>

  <!-- Platform Breakdown -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Platform Breakdown</h3>
      <DataSourceTag source={socialResult.source} name="Social" />
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Platform</th>
            <th class="num">Followers</th>
            <th class="num">Growth</th>
            <th class="num">Engagement</th>
            <th class="num">Referral Traffic</th>
            <th class="num">Posts</th>
          </tr>
        </thead>
        <tbody>
          {social.platforms.map((p) => (
            <tr>
              <td class="platform-name">{p.name}</td>
              <td class="num">{formatNumber(p.followers)}</td>
              <td class="num">
                <span class={p.followerGrowth >= 0 ? 'delta-pos' : 'delta-neg'}>
                  {p.followerGrowth >= 0 ? '+' : ''}{formatPercent(p.followerGrowth)}
                </span>
              </td>
              <td class="num">{formatPercent(p.engagementRate)}</td>
              <td class="num">{formatNumber(p.referralTraffic)}</td>
              <td class="num">{p.posts}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Top Posts -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Top Posts</h3>
      <DataSourceTag source={socialResult.source} name="Social" />
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Platform</th>
            <th>Content</th>
            <th class="num">Engagement</th>
            <th class="num">Reach</th>
            <th class="num">Clicks</th>
          </tr>
        </thead>
        <tbody>
          {social.topPosts.map((p) => (
            <tr>
              <td><span class="platform-badge">{p.platform}</span></td>
              <td class="post-content">{p.content.length > 60 ? p.content.slice(0, 60) + '…' : p.content}</td>
              <td class="num">{formatNumber(p.engagement)}</td>
              <td class="num">{formatNumber(p.reach)}</td>
              <td class="num">{formatNumber(p.clicks)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>

<style>
  .grid-kpi { margin-bottom: var(--space-6); }
  .grid-charts { margin-bottom: var(--space-6); }

  .table-section {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-6);
  }
  .table-section:last-child { margin-bottom: 0; }

  .table-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-default);
  }
  .table-title { font-size: var(--text-sm); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .table-wrapper { overflow-x: auto; }
  .data-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .data-table th { text-align: left; padding: var(--space-3) var(--space-5); font-size: var(--text-xs); font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid var(--border-default); }
  .data-table td { padding: var(--space-3) var(--space-5); color: var(--text-secondary); border-bottom: 1px solid var(--surface-2); }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--surface-2); }
  .num { text-align: right; font-variant-numeric: tabular-nums; }

  .platform-name { font-weight: 500; color: var(--text-primary); }
  .delta-pos { color: var(--accent-success); }
  .delta-neg { color: var(--accent-danger); }

  .platform-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    background: var(--surface-3);
    color: var(--text-secondary);
  }

  .post-content {
    font-size: var(--text-xs);
    color: var(--text-primary);
    max-width: 300px;
  }
</style>

<script define:vars={{ platformsData, referralData }}>
  window.__social_platforms = JSON.parse(platformsData);
  window.__social_referral = JSON.parse(referralData);
</script>

<script>
  import { lazyInitCharts } from '../utils/echarts-loader';

  lazyInitCharts([
    {
      id: 'social-followers-chart',
      setup: (echarts) => {
        const el = document.getElementById('social-followers-chart')!;
        const chart = echarts.init(el, 'dashboard', { devicePixelRatio: Math.max(window.devicePixelRatio, 2) });
        const platforms = (window as any).__social_platforms || [];

        chart.setOption({
          tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
          legend: { data: ['Followers', 'Growth %'], right: 10, top: 0 },
          grid: { left: '3%', right: '8%', bottom: '3%', top: '14%', containLabel: true },
          xAxis: { type: 'category', data: platforms.map((p: any) => p.name) },
          yAxis: [
            { type: 'value', name: 'Followers' },
            { type: 'value', name: 'Growth %', axisLabel: { formatter: '{value}%' } },
          ],
          series: [
            {
              name: 'Followers',
              type: 'bar',
              data: platforms.map((p: any) => p.followers),
              barMaxWidth: 40,
              itemStyle: { borderRadius: [4, 4, 0, 0] },
            },
            {
              name: 'Growth %',
              type: 'line',
              yAxisIndex: 1,
              data: platforms.map((p: any) => p.followerGrowth),
              symbolSize: 8,
              lineStyle: { width: 2 },
            },
          ],
        });
        window.addEventListener('resize', () => chart.resize());
      },
    },
    {
      id: 'social-referral-chart',
      setup: (echarts) => {
        const el = document.getElementById('social-referral-chart')!;
        const chart = echarts.init(el, 'dashboard', { devicePixelRatio: Math.max(window.devicePixelRatio, 2) });
        const raw = (window as any).__social_referral || [];

        const dates = [...new Set(raw.map((r: any) => r.date))].sort();
        const platforms = [...new Set(raw.map((r: any) => r.platform))];

        const series = (platforms as string[]).map((platform: string) => ({
          name: platform,
          type: 'line',
          stack: 'referral',
          areaStyle: { opacity: 0.3 },
          smooth: true,
          symbolSize: 0,
          lineStyle: { width: 1.5 },
          data: (dates as string[]).map((date: string) => {
            const entry = raw.find((r: any) => r.date === date && r.platform === platform);
            return entry ? entry.sessions : 0;
          }),
        }));

        chart.setOption({
          tooltip: { trigger: 'axis' },
          legend: { data: platforms, right: 10, top: 0, textStyle: { fontSize: 10 } },
          grid: { left: '3%', right: '4%', bottom: '3%', top: '14%', containLabel: true },
          xAxis: {
            type: 'category',
            data: dates,
            axisLabel: { formatter: (v: string) => { const d = new Date(v); return `${d.getMonth()+1}/${d.getDate()}`; }, interval: 6 },
          },
          yAxis: { type: 'value' },
          series,
        });
        window.addEventListener('resize', () => chart.resize());
      },
    },
  ]);
</script>
