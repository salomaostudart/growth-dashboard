---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import MetricCard from '../components/ui/MetricCard.astro';
import ChartContainer from '../components/charts/ChartContainer.astro';
import { getConnector } from '../connectors/registry';
import { formatNumber, formatPercent } from '../utils/formatters';

const now = new Date();
const dateRange = { start: new Date(now.getTime() - 30 * 86400000), end: now, range: '30d' as const };

const emailResult = await getConnector('email').fetch(dateRange);
const email = emailResult.data;

// Serialize for client charts
const campaignsData = JSON.stringify(email.campaigns);
const heatmapData = JSON.stringify(email.bestSendTimes);
---

<DashboardLayout title="Email Marketing" activeNav="email">
  <!-- KPI Cards -->
  <section class="grid-kpi">
    <MetricCard
      title="Open Rate"
      value={formatPercent(email.openRate)}
      delta={Number((email.openRate - 25).toFixed(1))}
      deltaLabel="vs benchmark 25%"
      source={emailResult.source}
      sourceName="Mailchimp"
      sparklineData={email.campaigns.map(c => c.openRate).reverse()}
    />
    <MetricCard
      title="Click Rate"
      value={formatPercent(email.clickRate)}
      delta={Number((email.clickRate - 4).toFixed(1))}
      deltaLabel="vs benchmark 4%"
      source={emailResult.source}
      sourceName="Mailchimp"
      sparklineData={email.campaigns.map(c => c.clickRate).reverse()}
    />
    <MetricCard
      title="Subscribers"
      value={formatNumber(email.totalSubscribers)}
      source={emailResult.source}
      sourceName="Mailchimp"
    />
    <MetricCard
      title="List Growth"
      value={formatPercent(email.listGrowthRate)}
      source={emailResult.source}
      sourceName="Mailchimp"
    />
    <MetricCard
      title="Unsubscribe Rate"
      value={formatPercent(email.unsubscribeRate)}
      source={emailResult.source}
      sourceName="Mailchimp"
    />
  </section>

  <!-- Charts -->
  <section class="grid-charts">
    <ChartContainer
      title="Campaign Performance"
      subtitle="Open rate & click rate by campaign"
      source={emailResult.source}
      sourceName="Mailchimp"
      id="email-campaigns-chart"
      height="340px"
    />
    <ChartContainer
      title="Best Send Times"
      subtitle="Engagement heatmap by day & hour"
      source={emailResult.source}
      sourceName="Mailchimp"
      id="email-heatmap-chart"
      height="340px"
    />
  </section>

  <!-- Campaigns Table -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Recent Campaigns</h3>
      <div class={`source-tag source-${emailResult.source}`}>
        <span class="source-dot"></span>
        <span>Mailchimp</span>
      </div>
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Campaign</th>
            <th class="num">Sent</th>
            <th class="num">Opens</th>
            <th class="num">Clicks</th>
            <th class="num">Open Rate</th>
            <th class="num">Click Rate</th>
          </tr>
        </thead>
        <tbody>
          {email.campaigns.map((c) => (
            <tr>
              <td class="campaign-name">{c.name}</td>
              <td class="num">{formatNumber(c.sent)}</td>
              <td class="num">{formatNumber(c.opens)}</td>
              <td class="num">{formatNumber(c.clicks)}</td>
              <td class="num">{formatPercent(c.openRate)}</td>
              <td class="num">{formatPercent(c.clickRate)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Automations -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Automations</h3>
      <div class={`source-tag source-${emailResult.source}`}>
        <span class="source-dot"></span>
        <span>Mailchimp</span>
      </div>
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Automation</th>
            <th>Status</th>
            <th class="num">Success Rate</th>
            <th class="num">Total Runs</th>
          </tr>
        </thead>
        <tbody>
          {email.automations.map((a) => (
            <tr>
              <td>{a.name}</td>
              <td>
                <span class={`status-pill status-${a.status}`}>{a.status}</span>
              </td>
              <td class="num">{formatPercent(a.successRate)}</td>
              <td class="num">{formatNumber(a.totalRuns)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>

<style>
  .grid-kpi { margin-bottom: var(--space-6); }
  .grid-charts { margin-bottom: var(--space-6); }

  .table-section {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-6);
  }
  .table-section:last-child { margin-bottom: 0; }

  .table-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-default);
  }
  .table-title {
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .source-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: var(--radius-full);
    font-weight: 500;
  }
  .source-dot { width: 5px; height: 5px; border-radius: 50%; }
  .source-live { background: var(--accent-success-dim); color: var(--accent-success); }
  .source-live .source-dot { background: var(--accent-success); }
  .source-mock { background: var(--surface-3); color: var(--text-muted); }
  .source-mock .source-dot { background: var(--text-muted); }

  .table-wrapper { overflow-x: auto; }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .data-table th {
    text-align: left;
    padding: var(--space-3) var(--space-5);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border-default);
  }
  .data-table td {
    padding: var(--space-3) var(--space-5);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--surface-2);
  }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--surface-2); }
  .num { text-align: right; font-variant-numeric: tabular-nums; }

  .campaign-name {
    font-weight: 500;
    color: var(--text-primary);
  }

  .status-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: capitalize;
  }
  .status-active { background: var(--accent-success-dim); color: var(--accent-success); }
  .status-paused { background: var(--accent-warning-dim); color: var(--accent-warning); }
  .status-draft { background: var(--surface-3); color: var(--text-muted); }
</style>

<script define:vars={{ campaignsData, heatmapData }}>
  window.__email_campaigns = JSON.parse(campaignsData);
  window.__email_heatmap = JSON.parse(heatmapData);
</script>

<script>
  import * as echarts from 'echarts';
  import { dashboardTheme } from '../utils/echarts-theme';

  echarts.registerTheme('dashboard', dashboardTheme);

  // Campaign Performance
  const campEl = document.getElementById('email-campaigns-chart');
  if (campEl) {
    const chart = echarts.init(campEl, 'dashboard');
    const campaigns = (window as any).__email_campaigns || [];

    chart.setOption({
      tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },
      legend: { data: ['Open Rate', 'Click Rate'], right: 10, top: 0 },
      grid: { left: '3%', right: '4%', bottom: '3%', top: '14%', containLabel: true },
      xAxis: {
        type: 'category',
        data: campaigns.map((c: any) => c.name.length > 15 ? c.name.slice(0, 15) + '…' : c.name),
        axisLabel: { rotate: 35, fontSize: 10 },
      },
      yAxis: { type: 'value', axisLabel: { formatter: '{value}%' } },
      series: [
        {
          name: 'Open Rate',
          type: 'bar',
          data: campaigns.map((c: any) => c.openRate),
          barMaxWidth: 24,
          itemStyle: { borderRadius: [4, 4, 0, 0] },
        },
        {
          name: 'Click Rate',
          type: 'bar',
          data: campaigns.map((c: any) => c.clickRate),
          barMaxWidth: 24,
          itemStyle: { borderRadius: [4, 4, 0, 0] },
        },
      ],
    });
    window.addEventListener('resize', () => chart.resize());
  }

  // Send Times Heatmap
  const heatEl = document.getElementById('email-heatmap-chart');
  if (heatEl) {
    const chart = echarts.init(heatEl, 'dashboard');
    const raw = (window as any).__email_heatmap || [];
    const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const hours = Array.from({ length: 16 }, (_, i) => `${i + 6}:00`);

    const data = raw.map((d: any) => [d.hour - 6, d.day, d.engagement]);
    const maxVal = Math.max(...raw.map((d: any) => d.engagement));

    chart.setOption({
      tooltip: {
        formatter: (p: any) => `${days[p.value[1]]} ${hours[p.value[0]]}<br/>Engagement: ${p.value[2]}`,
      },
      grid: { left: '8%', right: '12%', bottom: '10%', top: '5%' },
      xAxis: { type: 'category', data: hours, axisLabel: { fontSize: 9, interval: 2 } },
      yAxis: { type: 'category', data: days, axisLabel: { fontSize: 10 } },
      visualMap: {
        min: 0,
        max: maxVal,
        calculable: true,
        orient: 'vertical',
        right: 0,
        top: 'center',
        inRange: { color: ['#1a1a24', '#242432', '#4f46e5', '#818cf8', '#a5b4fc'] },
        textStyle: { color: '#8892a8', fontSize: 10 },
      },
      series: [{
        type: 'heatmap',
        data,
        label: { show: false },
        emphasis: { itemStyle: { shadowBlur: 10, shadowColor: 'rgba(129,140,248,0.5)' } },
      }],
    });
    window.addEventListener('resize', () => chart.resize());
  }
</script>
