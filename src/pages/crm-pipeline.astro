---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import MetricCard from '../components/ui/MetricCard.astro';
import ChartContainer from '../components/charts/ChartContainer.astro';
import { getConnector } from '../connectors/registry';
import { formatNumber, formatCurrency, calcDelta } from '../utils/formatters';
import DataSourceTag from '../components/ui/DataSourceTag.astro';

import { getDefaultDateRange } from '../utils/date-range';
const dateRange = getDefaultDateRange('30d');

const crmResult = await getConnector('crm').fetch(dateRange);
const crm = crmResult.data;

// Funnel conversion rates
const mqlRate = crm.funnel.leads > 0 ? (crm.funnel.mql / crm.funnel.leads * 100) : 0;
const sqlRate = crm.funnel.mql > 0 ? (crm.funnel.sql / crm.funnel.mql * 100) : 0;
const winRate = crm.funnel.pipeline > 0 ? (crm.funnel.won / crm.funnel.pipeline * 100) : 0;

const fmt = (v: number | null) => v !== null ? Number(v.toFixed(1)) : undefined;
const leadsDelta = fmt(calcDelta(crm.leadVelocity.map(d => d.leads)));

// Serialize for client
const funnelData = JSON.stringify(crm.funnel);
const velocityData = JSON.stringify(crm.leadVelocity);
---

<DashboardLayout title="CRM & Pipeline" activeNav="crm-pipeline">
  <!-- KPI Cards -->
  <section class="grid-kpi">
    <MetricCard
      title="Leads"
      value={formatNumber(crm.funnel.leads)}
      delta={leadsDelta}
      source={crmResult.source}
      sourceName="HubSpot"
      sparklineData={crm.leadVelocity.slice(-14).map(d => d.leads)}
    />
    <MetricCard
      title="MQLs"
      value={`${formatNumber(crm.funnel.mql)} (${mqlRate.toFixed(0)}%)`}
      source={crmResult.source}
      sourceName="HubSpot"
    />
    <MetricCard
      title="SQLs"
      value={`${formatNumber(crm.funnel.sql)} (${sqlRate.toFixed(0)}%)`}
      source={crmResult.source}
      sourceName="HubSpot"
    />
    <MetricCard
      title="Pipeline"
      value={formatNumber(crm.funnel.pipeline)}
      source={crmResult.source}
      sourceName="HubSpot"
    />
    <MetricCard
      title="Won"
      value={formatNumber(crm.funnel.won)}
      delta={Number(winRate.toFixed(1))}
      deltaLabel="win rate"
      source={crmResult.source}
      sourceName="HubSpot"
    />
  </section>

  <!-- Charts -->
  <section class="grid-charts">
    <ChartContainer
      title="Conversion Funnel"
      subtitle="Leads → MQL → SQL → Pipeline → Won"
      source={crmResult.source}
      sourceName="HubSpot"
      id="crm-funnel-chart"
      height="340px"
    />
    <ChartContainer
      title="Lead Velocity"
      subtitle="Daily new leads — last 30 days"
      source={crmResult.source}
      sourceName="HubSpot"
      id="crm-velocity-chart"
      height="340px"
    />
  </section>

  <!-- Channel Attribution -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Channel Attribution</h3>
      <DataSourceTag source={crmResult.source} name="HubSpot" />
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Channel</th>
            <th class="num">Leads</th>
            <th class="num">MQL</th>
            <th class="num">SQL</th>
            <th class="num">Pipeline</th>
            <th class="num">Won</th>
            <th class="num">CAC</th>
          </tr>
        </thead>
        <tbody>
          {crm.channelAttribution.map((ch) => (
            <tr>
              <td class="channel-name">{ch.channel}</td>
              <td class="num">{formatNumber(ch.leads)}</td>
              <td class="num">{formatNumber(ch.mql)}</td>
              <td class="num">{formatNumber(ch.sql)}</td>
              <td class="num">{formatNumber(ch.pipeline)}</td>
              <td class="num">{formatNumber(ch.won)}</td>
              <td class="num">{formatCurrency(ch.cac)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Pipeline by Stage -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Pipeline by Stage</h3>
      <DataSourceTag source={crmResult.source} name="HubSpot" />
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Stage</th>
            <th class="num">Value</th>
            <th class="num">Count</th>
            <th>Confidence</th>
          </tr>
        </thead>
        <tbody>
          {crm.pipelineByStage.map((s) => (
            <tr>
              <td class="stage-name">{s.stage}</td>
              <td class="num">{formatCurrency(s.value)}</td>
              <td class="num">{s.count}</td>
              <td>
                <span class={`conf-badge conf-${s.confidence}`}>{s.confidence}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>

<style>
  .grid-kpi { margin-bottom: var(--space-6); }
  .grid-charts { margin-bottom: var(--space-6); }

  .table-section {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-6);
  }
  .table-section:last-child { margin-bottom: 0; }
  .table-header { display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--border-default); }
  .table-title { font-size: var(--text-sm); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .table-wrapper { overflow-x: auto; }
  .data-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .data-table th { text-align: left; padding: var(--space-3) var(--space-5); font-size: var(--text-xs); font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid var(--border-default); }
  .data-table td { padding: var(--space-3) var(--space-5); color: var(--text-secondary); border-bottom: 1px solid var(--surface-2); }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--surface-2); }
  .num { text-align: right; font-variant-numeric: tabular-nums; }

  .channel-name, .stage-name { font-weight: 500; color: var(--text-primary); }

  .conf-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: capitalize;
  }
  .conf-high { background: var(--accent-success-dim); color: var(--accent-success); }
  .conf-medium { background: var(--accent-warning-dim); color: var(--accent-warning); }
  .conf-low { background: var(--surface-3); color: var(--text-muted); }
</style>

<script define:vars={{ funnelData, velocityData }}>
  window.__crm_funnel = JSON.parse(funnelData);
  window.__crm_velocity = JSON.parse(velocityData);
</script>

<script>
  import echarts from '../utils/echarts-setup';
  import { dashboardTheme } from '../utils/echarts-theme';

  echarts.registerTheme('dashboard', dashboardTheme);

  // Funnel chart
  const funnelEl = document.getElementById('crm-funnel-chart');
  if (funnelEl) {
    const chart = echarts.init(funnelEl, 'dashboard', { devicePixelRatio: Math.max(window.devicePixelRatio, 2) });
    const funnel = (window as any).__crm_funnel || {};

    chart.setOption({
      tooltip: { trigger: 'item', formatter: '{b}: {c}' },
      series: [{
        type: 'funnel',
        left: '10%',
        top: '10%',
        bottom: '10%',
        width: '80%',
        sort: 'descending',
        gap: 4,
        label: { show: true, position: 'inside', fontSize: 12, color: '#f1f5f9' },
        itemStyle: { borderColor: '#111118', borderWidth: 2, borderRadius: 4 },
        data: [
          { value: funnel.leads || 0, name: 'Leads' },
          { value: funnel.mql || 0, name: 'MQL' },
          { value: funnel.sql || 0, name: 'SQL' },
          { value: funnel.pipeline || 0, name: 'Pipeline' },
          { value: funnel.won || 0, name: 'Won' },
        ],
      }],
    });
    window.addEventListener('resize', () => chart.resize());
  }

  // Lead Velocity
  const velEl = document.getElementById('crm-velocity-chart');
  if (velEl) {
    const chart = echarts.init(velEl, 'dashboard', { devicePixelRatio: Math.max(window.devicePixelRatio, 2) });
    const velocity = (window as any).__crm_velocity || [];

    chart.setOption({
      tooltip: { trigger: 'axis' },
      grid: { left: '3%', right: '4%', bottom: '3%', top: '10%', containLabel: true },
      xAxis: {
        type: 'category',
        data: velocity.map((d: any) => d.date),
        axisLabel: { formatter: (v: string) => { const d = new Date(v); return `${d.getMonth()+1}/${d.getDate()}`; }, interval: 6 },
      },
      yAxis: { type: 'value', name: 'Leads' },
      series: [{
        type: 'bar',
        data: velocity.map((d: any) => d.leads),
        barMaxWidth: 12,
        itemStyle: { borderRadius: [2, 2, 0, 0] },
      }],
    });
    window.addEventListener('resize', () => chart.resize());
  }
</script>
