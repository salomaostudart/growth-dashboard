---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getConnector } from '../connectors/registry';
import { formatNumber, formatPercent, formatCurrency } from '../utils/formatters';
import { generateInsights } from '../utils/insights-engine';
import { generateExecutiveReport } from '../utils/report-generator';

import { getDefaultDateRange } from '../utils/date-range';
const dateRange = getDefaultDateRange('90d');

const [webR, seoR, emailR, socialR, crmR, martechR] = await Promise.all([
  getConnector('web').fetch(dateRange),
  getConnector('seo').fetch(dateRange),
  getConnector('email').fetch(dateRange),
  getConnector('social').fetch(dateRange),
  getConnector('crm').fetch(dateRange),
  getConnector('martech').fetch(dateRange),
]);

const web = webR.data;
const seo = seoR.data;
const email = emailR.data;
const social = socialR.data;
const crm = crmR.data;
const martech = martechR.data;

const insights = generateInsights({ web, seo, email, crm, martech });
const topInsights = insights.slice(0, 5);
const recommendations = insights.filter(i => i.type === 'negative').slice(0, 5);

const currentDate = new Date().toISOString().split('T')[0];

// KPI rows: metric_name, current_value (raw), target (raw), category, display format
interface KpiRow {
  metric: string;
  category: string;
  current: number;
  target: number | null;
  direction: 'higher' | 'lower';
  format: 'number' | 'percent' | 'currency';
}

const kpiRows: KpiRow[] = [
  { metric: 'Sessions', category: 'Web', current: web.sessions, target: web.targets?.sessions?.target ?? null, direction: 'higher', format: 'number' },
  { metric: 'Users', category: 'Web', current: web.users, target: web.targets?.users?.target ?? null, direction: 'higher', format: 'number' },
  { metric: 'Bounce Rate', category: 'Web', current: web.bounceRate, target: web.targets?.bounceRate?.target ?? null, direction: 'lower', format: 'percent' },
  { metric: 'Conversion Rate', category: 'Web', current: web.conversionRate, target: web.targets?.conversionRate?.target ?? null, direction: 'higher', format: 'percent' },
  { metric: 'Impressions', category: 'SEO', current: seo.impressions, target: seo.targets?.impressions?.target ?? null, direction: 'higher', format: 'number' },
  { metric: 'Clicks', category: 'SEO', current: seo.clicks, target: seo.targets?.clicks?.target ?? null, direction: 'higher', format: 'number' },
  { metric: 'Avg Position', category: 'SEO', current: seo.avgPosition, target: seo.targets?.avgPosition?.target ?? null, direction: 'lower', format: 'number' },
  { metric: 'Open Rate', category: 'Email', current: email.openRate, target: email.targets?.openRate?.target ?? null, direction: 'higher', format: 'percent' },
  { metric: 'Click Rate', category: 'Email', current: email.clickRate, target: email.targets?.clickRate?.target ?? null, direction: 'higher', format: 'percent' },
  { metric: 'Leads', category: 'CRM', current: crm.funnel.leads, target: crm.targets?.leads?.target ?? null, direction: 'higher', format: 'number' },
  { metric: 'MQL', category: 'CRM', current: crm.funnel.mql, target: crm.targets?.mql?.target ?? null, direction: 'higher', format: 'number' },
  { metric: 'SQL', category: 'CRM', current: crm.funnel.sql, target: crm.targets?.sql?.target ?? null, direction: 'higher', format: 'number' },
];

function formatValue(val: number, fmt: 'number' | 'percent' | 'currency'): string {
  if (fmt === 'number') return formatNumber(val);
  if (fmt === 'percent') return formatPercent(val);
  return formatCurrency(val);
}

function pctOfTarget(current: number, target: number, direction: 'higher' | 'lower'): number {
  if (direction === 'lower') {
    // For lower-is-better: 100% means at target, >100% means better than target
    return target > 0 ? (target / current) * 100 : 0;
  }
  return target > 0 ? (current / target) * 100 : 0;
}

function targetStatus(pct: number): 'on-track' | 'warning' | 'behind' {
  if (pct >= 90) return 'on-track';
  if (pct >= 70) return 'warning';
  return 'behind';
}

// Channel performance summary
const channelRows = [
  { channel: 'Organic', sessions: Math.round(web.sessions * web.channelMix.organic / 100), share: web.channelMix.organic },
  { channel: 'Direct', sessions: Math.round(web.sessions * web.channelMix.direct / 100), share: web.channelMix.direct },
  { channel: 'Paid', sessions: Math.round(web.sessions * web.channelMix.paid / 100), share: web.channelMix.paid },
  { channel: 'Social', sessions: Math.round(web.sessions * web.channelMix.social / 100), share: web.channelMix.social },
  { channel: 'Email', sessions: Math.round(web.sessions * web.channelMix.email / 100), share: web.channelMix.email },
  { channel: 'Referral', sessions: Math.round(web.sessions * web.channelMix.referral / 100), share: web.channelMix.referral },
].sort((a, b) => b.sessions - a.sessions);

// Serialize for client-side download
const reportData = {
  kpiRows,
  insights,
  web: {
    sessions: web.sessions,
    users: web.users,
    bounceRate: web.bounceRate,
    conversionRate: web.conversionRate,
    channelMix: web.channelMix,
  },
  seo: { impressions: seo.impressions, clicks: seo.clicks, ctr: seo.ctr, avgPosition: seo.avgPosition },
  email: { openRate: email.openRate, clickRate: email.clickRate, totalSubscribers: email.totalSubscribers },
  crm: { funnel: crm.funnel },
  social: { platforms: social.platforms.map(p => ({ name: p.name, followers: p.followers, engagementRate: p.engagementRate })) },
};

// Pre-generate markdown on server side for MD download
const mdReport = generateExecutiveReport({ web, seo, email, social, crm, martech });
---

<DashboardLayout title="Growth Report" activeNav="report">
  <div class="report-page">

    <!-- Page Header -->
    <div class="report-header">
      <div class="report-header-left">
        <h2 class="report-title">Growth Report</h2>
        <p class="report-meta">Generated {currentDate} &mdash; Last 90 days</p>
      </div>
      <div class="report-actions">
        <button class="btn-download" id="btn-csv" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download CSV
        </button>
        <button class="btn-download btn-md" id="btn-md" type="button">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Download Report (MD)
        </button>
      </div>
    </div>

    <!-- Executive Summary -->
    <section class="report-section">
      <h3 class="section-title">Executive Summary</h3>
      <div class="insights-grid">
        {topInsights.map(insight => (
          <div class:list={['insight-card', `insight-${insight.type}`]}>
            <div class="insight-header">
              <span class:list={['insight-badge', `badge-${insight.type}`]}>{insight.type}</span>
              <span class="insight-category">{insight.category}</span>
            </div>
            <p class="insight-title">{insight.title}</p>
            <p class="insight-desc">{insight.description}</p>
            {insight.value && <span class="insight-value">{insight.value}</span>}
          </div>
        ))}
      </div>
    </section>

    <!-- KPI Overview -->
    <section class="report-section">
      <h3 class="section-title">KPI Overview</h3>
      <div class="table-wrapper">
        <table class="report-table" id="kpi-table">
          <thead>
            <tr>
              <th>Metric</th>
              <th>Category</th>
              <th>Current</th>
              <th>Target</th>
              <th>% of Target</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {kpiRows.map(row => {
              const pct = row.target ? pctOfTarget(row.current, row.target, row.direction) : null;
              const status = pct ? targetStatus(pct) : null;
              return (
                <tr>
                  <td class="metric-name">{row.metric}</td>
                  <td><span class="category-tag">{row.category}</span></td>
                  <td class="metric-value">{formatValue(row.current, row.format)}</td>
                  <td class="metric-target">{row.target ? formatValue(row.target, row.format) : '—'}</td>
                  <td class="metric-pct">{pct ? `${pct.toFixed(0)}%` : '—'}</td>
                  <td>
                    {status && (
                      <span class:list={['status-pill', `status-${status}`]}>
                        {status === 'on-track' ? 'On Track' : status === 'warning' ? 'Warning' : 'Behind'}
                      </span>
                    )}
                    {!status && <span class="status-pill status-neutral">No Target</span>}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Channel Performance -->
    <section class="report-section">
      <h3 class="section-title">Channel Performance</h3>
      <div class="table-wrapper">
        <table class="report-table" id="channel-table">
          <thead>
            <tr>
              <th>Channel</th>
              <th>Sessions</th>
              <th>Share of Traffic</th>
              <th>Bar</th>
            </tr>
          </thead>
          <tbody>
            {channelRows.map(row => (
              <tr>
                <td class="metric-name">{row.channel}</td>
                <td class="metric-value">{formatNumber(row.sessions)}</td>
                <td class="metric-pct">{formatPercent(row.share)}</td>
                <td class="bar-cell">
                  <div class="bar-bg">
                    <div class="bar-fill" style={`width: ${Math.min(row.share, 100)}%`}></div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Recommendations -->
    <section class="report-section">
      <h3 class="section-title">Recommendations</h3>
      {recommendations.length === 0 && (
        <p class="no-recs">No critical issues detected. All key metrics are within acceptable ranges.</p>
      )}
      <div class="recs-list">
        {recommendations.map((rec, i) => (
          <div class="rec-card">
            <div class="rec-number">{i + 1}</div>
            <div class="rec-content">
              <p class="rec-title">{rec.title}</p>
              <p class="rec-action">{rec.description}</p>
              <div class="rec-meta">
                <span class="rec-category">{rec.category}</span>
                {rec.value && <span class="rec-value">{rec.value}</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</DashboardLayout>

<script define:vars={{ reportData, mdReport, currentDate }}>
  // CSV Download
  document.getElementById('btn-csv')?.addEventListener('click', () => {
    const rows = [
      ['metric_name', 'current_value', 'target', 'pct_of_target', 'category'],
    ];

    reportData.kpiRows.forEach(row => {
      const pct = row.target
        ? row.direction === 'lower'
          ? ((row.target / row.current) * 100).toFixed(1)
          : ((row.current / row.target) * 100).toFixed(1)
        : '';
      rows.push([
        row.metric,
        String(row.current),
        row.target ? String(row.target) : '',
        pct,
        row.category,
      ]);
    });

    const csv = rows.map(r => r.map(cell => `"${String(cell).replace(/"/g, '""')}"`).join(',')).join('\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `growth-report_${currentDate}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // MD Download
  document.getElementById('btn-md')?.addEventListener('click', () => {
    const blob = new Blob([mdReport], { type: 'text/markdown;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `growth-report_${currentDate}.md`;
    a.click();
    URL.revokeObjectURL(url);
  });
</script>

<style>
  .report-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* Header */
  .report-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .report-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .report-meta {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: var(--space-1) 0 0;
  }

  .report-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .btn-download {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--surface-2);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .btn-download:hover {
    background: var(--surface-3);
    color: var(--text-primary);
    border-color: var(--border-hover);
  }

  .btn-md {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  .btn-md:hover {
    background: rgba(129, 140, 248, 0.12);
    color: var(--accent-primary);
  }

  /* Sections */
  .report-section {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-5);
  }

  /* Insights grid */
  .insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .insight-card {
    background: var(--surface-2);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .insight-card.insight-positive { border-left: 3px solid var(--accent-success); }
  .insight-card.insight-negative { border-left: 3px solid var(--accent-danger); }
  .insight-card.insight-neutral { border-left: 3px solid var(--accent-primary); }

  .insight-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .insight-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .badge-positive { background: rgba(52, 211, 153, 0.12); color: var(--accent-success); }
  .badge-negative { background: rgba(248, 113, 113, 0.12); color: var(--accent-danger); }
  .badge-neutral { background: rgba(129, 140, 248, 0.12); color: var(--accent-primary); }

  .insight-category {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .insight-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .insight-desc {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .insight-value {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }

  /* Tables */
  .table-wrapper {
    overflow-x: auto;
  }

  .report-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .report-table thead th {
    text-align: left;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-default);
    white-space: nowrap;
  }

  .report-table tbody tr {
    border-bottom: 1px solid var(--border-subtle, rgba(255,255,255,0.04));
    transition: background var(--transition-fast);
  }

  .report-table tbody tr:hover {
    background: var(--surface-2);
  }

  .report-table tbody td {
    padding: var(--space-3);
    color: var(--text-secondary);
    vertical-align: middle;
  }

  .metric-name {
    color: var(--text-primary) !important;
    font-weight: 500;
  }

  .metric-value {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--text-primary) !important;
  }

  .metric-pct {
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary) !important;
  }

  .metric-target {
    color: var(--text-muted) !important;
    font-variant-numeric: tabular-nums;
  }

  .category-tag {
    font-size: var(--text-xs);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    background: var(--surface-3);
    color: var(--text-muted);
  }

  .status-pill {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .status-on-track { background: rgba(52, 211, 153, 0.12); color: var(--accent-success); }
  .status-warning { background: rgba(251, 191, 36, 0.12); color: #fbbf24; }
  .status-behind { background: rgba(248, 113, 113, 0.12); color: var(--accent-danger); }
  .status-neutral { background: var(--surface-3); color: var(--text-muted); }

  /* Bar chart cell */
  .bar-cell { min-width: 100px; }
  .bar-bg {
    height: 6px;
    background: var(--surface-3);
    border-radius: 3px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: var(--accent-primary);
    border-radius: 3px;
    transition: width 0.6s ease;
  }

  /* Recommendations */
  .no-recs {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0;
  }

  .recs-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .rec-card {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    background: var(--surface-2);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .rec-number {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(248, 113, 113, 0.12);
    color: var(--accent-danger);
    font-size: var(--text-sm);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .rec-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .rec-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .rec-action {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  .rec-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .rec-category {
    font-size: var(--text-xs);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    background: var(--surface-3);
    color: var(--text-muted);
  }

  .rec-value {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-danger);
  }

  @media (max-width: 640px) {
    .report-header { flex-direction: column; }
    .insights-grid { grid-template-columns: 1fr; }
  }
</style>
