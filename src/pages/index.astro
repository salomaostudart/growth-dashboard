---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import MetricCard from '../components/ui/MetricCard.astro';
import ChartContainer from '../components/charts/ChartContainer.astro';
import AlertBanner from '../components/ui/AlertBanner.astro';
import { getConnector, getAllConnectors } from '../connectors/registry';
import { formatNumber, formatPercent, calcDelta } from '../utils/formatters';
import { generateInsights } from '../utils/insights-engine';

import { getDefaultDateRange } from '../utils/date-range';
const dateRange = getDefaultDateRange('30d');

const webResult = await getConnector('web').fetch(dateRange);
const seoResult = await getConnector('seo').fetch(dateRange);
const emailResult = await getConnector('email').fetch(dateRange);
const crmResult = await getConnector('crm').fetch(dateRange);
const martechResult = await getConnector('martech').fetch(dateRange);

const web = webResult.data;
const seo = seoResult.data;
const email = emailResult.data;
const crm = crmResult.data;
const martech = martechResult.data;

// System health summary
const healthySystems = martech.systems.filter(s => s.status === 'healthy').length;
const totalSystems = martech.systems.length;

// Generate sparkline data from traffic
const sessionSparkline = web.trafficByDay.slice(-14).map(d => d.sessions);

// Alerts
const alerts: Array<{ type: 'warning' | 'danger' | 'info'; message: string; metric?: string; value?: string }> = [];
if (web.bounceRate > 55) alerts.push({ type: 'warning', message: 'Bounce rate above threshold', metric: 'Bounce Rate', value: formatPercent(web.bounceRate) });
const degradedSystems = martech.systems.filter(s => s.status !== 'healthy');
degradedSystems.forEach(s => alerts.push({ type: 'danger', message: `${s.name} is ${s.status}`, metric: 'Uptime', value: formatPercent(s.uptime) }));

// Connector sources for all cards
const connectors = getAllConnectors();

const fmt = (v: number | null) => v !== null ? Number(v.toFixed(1)) : undefined;
const sessionsDelta = fmt(calcDelta(web.trafficByDay.map(d => d.sessions)));
const impressionsDelta = fmt(calcDelta(seo.topQueries.map(q => q.impressions)));
const conversionDelta = fmt(calcDelta(web.trafficByDay.map(d => d.sessions * web.conversionRate / 100)));
const pipelineDelta = fmt(calcDelta(crm.leadVelocity.map(d => d.leads)));

// Insights
const insights = generateInsights({ web, seo, email, crm, martech });

// Serialize data for client-side charts
const trafficChartData = JSON.stringify(web.trafficByDay);
const channelMixData = JSON.stringify(web.channelMix);
---

<DashboardLayout title="Command Center" activeNav="overview">

  <!-- Alerts -->
  {alerts.length > 0 && (
    <section class="alerts-section">
      {alerts.map(alert => (
        <AlertBanner type={alert.type} message={alert.message} metric={alert.metric} value={alert.value} />
      ))}
    </section>
  )}

  <!-- KPI Cards -->
  <section class="grid-kpi">
    <MetricCard
      title="Sessions"
      value={formatNumber(web.sessions)}
      delta={sessionsDelta}
      source={webResult.source}
      sourceName="GA4"
      sparklineData={sessionSparkline}
      tooltip="Total visits to your sites in the selected period. A session ends after 30 minutes of inactivity."
    />
    <MetricCard
      title="Organic Impressions"
      value={formatNumber(seo.impressions)}
      delta={impressionsDelta}
      source={seoResult.source}
      sourceName="Search Console"
      sparklineData={seo.topQueries.slice(0, 14).map(q => q.impressions)}
      tooltip="How many times your pages appeared in Google search results. Higher impressions = more search visibility."
    />
    <MetricCard
      title="Email Open Rate"
      value={formatPercent(email.openRate)}
      delta={Number((email.openRate - 25).toFixed(1))}
      deltaLabel="vs benchmark 25%"
      source={emailResult.source}
      sourceName="Mailchimp"
      sparklineData={email.campaigns.map(c => c.openRate).reverse()}
      tooltip="Percentage of delivered emails that were opened. Industry average for B2B is ~21-25%."
    />
    <MetricCard
      title="Pipeline Influenced"
      value={formatNumber(crm.funnel.pipeline)}
      delta={pipelineDelta}

      source={crmResult.source}
      sourceName="HubSpot"
      sparklineData={crm.leadVelocity.slice(-14).map(d => d.leads)}
      tooltip="Deals in pipeline that were influenced by marketing touchpoints. Shows marketing's revenue contribution."
    />
    <MetricCard
      title="Conversion Rate"
      value={formatPercent(web.conversionRate)}
      delta={conversionDelta}
      source={webResult.source}
      sourceName="GA4"
      sparklineData={web.trafficByDay.slice(-14).map(d => d.sessions * web.conversionRate / 100)}
      tooltip="Percentage of sessions that completed a goal (form submit, demo request, signup)."
    />
    <MetricCard
      title="System Health"
      value={`${healthySystems}/${totalSystems}`}
      source={martechResult.source}
      sourceName="Martech"
      sparklineData={[]}
      tooltip="Number of martech systems reporting healthy status. Monitors uptime, latency, and sync status."
    />
  </section>

  <!-- Charts row -->
  <section class="grid-charts">
    <ChartContainer
      title="Traffic Trend"
      subtitle="Sessions over last 90 days"
      source={webResult.source}
      sourceName="GA4"
      id="traffic-trend-chart"
      height="320px"
    />
    <ChartContainer
      title="Channel Mix"
      subtitle="Traffic source distribution"
      source={webResult.source}
      sourceName="GA4"
      id="channel-mix-chart"
      height="320px"
    />
  </section>

  <!-- Insights -->
  {insights.length > 0 && (
    <section class="insights-section">
      <h3 class="section-title">Automated Insights</h3>
      <div class="insights-grid">
        {insights.map(insight => (
          <div class={`insight-card insight-${insight.type}`}>
            <div class="insight-header">
              <span class="insight-icon">{insight.type === 'positive' ? '\u2191' : insight.type === 'negative' ? '\u2193' : '\u2192'}</span>
              <span class="insight-category">{insight.category}</span>
            </div>
            <h4 class="insight-title">{insight.title}</h4>
            <p class="insight-desc">{insight.description}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Data Sources Status -->
  <section class="status-strip">
    <h3 class="strip-title">Data Sources</h3>
    <div class="strip-items">
      {Object.entries(connectors).map(([, connector]) => (
        <div class="strip-item">
          <span class={`strip-dot strip-${connector.source}`}></span>
          <span class="strip-name">{connector.name.replace(' (Mock)', '')}</span>
          <span class="strip-source">{connector.source}</span>
        </div>
      ))}
    </div>
  </section>
</DashboardLayout>

<style>
  .alerts-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .grid-kpi {
    margin-bottom: var(--space-6);
  }

  .grid-charts {
    margin-bottom: var(--space-6);
  }

  .status-strip {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
  }

  .strip-title {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
  }

  .strip-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-3);
  }

  .strip-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }

  .strip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .strip-live { background: var(--accent-success); }
  .strip-mock { background: var(--text-muted); }
  .strip-cached { background: var(--accent-warning); }
  .strip-error { background: var(--accent-danger); }

  .strip-name { font-weight: 500; }

  .strip-source {
    color: var(--text-muted);
    font-size: 10px;
    text-transform: uppercase;
    margin-left: auto;
  }

  .insights-section { margin-bottom: var(--space-6); }
  .section-title {
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
  }
  .insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  .insight-card {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    border-left: 3px solid;
  }
  .insight-positive { border-left-color: var(--accent-success); }
  .insight-negative { border-left-color: var(--accent-danger); }
  .insight-neutral { border-left-color: var(--accent-primary); }
  .insight-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .insight-icon { font-size: var(--text-sm); }
  .insight-positive .insight-icon { color: var(--accent-success); }
  .insight-negative .insight-icon { color: var(--accent-danger); }
  .insight-neutral .insight-icon { color: var(--accent-primary); }
  .insight-category {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
  .insight-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 var(--space-1) 0;
  }
  .insight-desc {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
</style>

<script define:vars={{ trafficChartData, channelMixData }}>
  // Bridge: server data → client scripts via window
  window.__traffic_data = JSON.parse(trafficChartData);
  window.__channel_data = JSON.parse(channelMixData);
</script>

<script>
  import echarts from '../utils/echarts-setup';
  import { dashboardTheme } from '../utils/echarts-theme';

  echarts.registerTheme('dashboard', dashboardTheme);

  // Traffic Trend Chart — uses server data from connectors
  const trafficEl = document.getElementById('traffic-trend-chart');
  if (trafficEl) {
    const chart = echarts.init(trafficEl, 'dashboard');
    const data = (window as any).__traffic_data || [];

    chart.setOption({
      tooltip: { trigger: 'axis' },
      legend: { data: ['Sessions', 'Users'], right: 10, top: 0 },
      xAxis: {
        type: 'category',
        data: data.map((d: any) => d.date),
        axisLabel: {
          formatter: (val: string) => {
            const d = new Date(val);
            return `${d.getMonth() + 1}/${d.getDate()}`;
          },
          interval: 13,
        },
      },
      yAxis: { type: 'value' },
      series: [
        {
          name: 'Sessions',
          type: 'line',
          data: data.map((d: any) => d.sessions),
          smooth: true,
          lineStyle: { width: 2 },
          areaStyle: { opacity: 0.08 },
          symbolSize: 0,
        },
        {
          name: 'Users',
          type: 'line',
          data: data.map((d: any) => d.users),
          smooth: true,
          lineStyle: { width: 2 },
          areaStyle: { opacity: 0.08 },
          symbolSize: 0,
        },
      ],
    });

    window.addEventListener('resize', () => chart.resize());
  }

  // Channel Mix Chart — uses server data from connectors
  const channelEl = document.getElementById('channel-mix-chart');
  if (channelEl) {
    const chart = echarts.init(channelEl, 'dashboard', { devicePixelRatio: Math.max(window.devicePixelRatio, 2) });
    const mix = (window as any).__channel_data || {};

    chart.setOption({
      tooltip: {
        trigger: 'item',
        formatter: '{b}: {d}%',
      },
      series: [{
        type: 'pie',
        radius: ['45%', '70%'],
        center: ['50%', '55%'],
        avoidLabelOverlap: true,
        itemStyle: {
          borderRadius: 3,
          borderColor: '#111118',
          borderWidth: 2,
        },
        label: {
          color: '#8892a8',
          fontSize: 11,
        },
        labelLayout: {
          hideOverlap: true,
        },
        data: [
          { value: mix.organic || 0, name: 'Organic' },
          { value: mix.direct || 0, name: 'Direct' },
          { value: mix.paid || 0, name: 'Paid' },
          { value: mix.social || 0, name: 'Social' },
          { value: mix.email || 0, name: 'Email' },
          { value: mix.referral || 0, name: 'Referral' },
        ],
      }],
    });

    window.addEventListener('resize', () => chart.resize());
  }
</script>
