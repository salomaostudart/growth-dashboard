---
import ChartContainer from '../components/charts/ChartContainer.astro';
import DataSourceTag from '../components/ui/DataSourceTag.astro';
import MetricCard from '../components/ui/MetricCard.astro';
import StatusBadge from '../components/ui/StatusBadge.astro';
import { getConnector } from '../connectors/registry';
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { formatCurrency, formatLatency, formatPercent, timeAgo } from '../utils/formatters';

import { getDefaultDateRange } from '../utils/date-range';
const dateRange = getDefaultDateRange('30d');

const martechResult = await getConnector('martech').fetch(dateRange);
const martech = martechResult.data;

// Aggregates
const healthySystems = martech.systems.filter((s) => s.status === 'healthy').length;
const totalSystems = martech.systems.length;
const avgUptime =
  totalSystems > 0 ? martech.systems.reduce((a, s) => a + s.uptime, 0) / totalSystems : 0;
const totalCost = martech.systems.reduce((a, s) => a + s.monthlyCost, 0);
const avgLatency =
  totalSystems > 0 ? martech.systems.reduce((a, s) => a + s.latencyMs, 0) / totalSystems : 0;

// Maturity score (0-100): weighted by status, uptime, latency
function calcMaturityScore(): number {
  let score = 0;
  for (const s of martech.systems) {
    let sysScore = 0;
    if (s.status === 'healthy') sysScore += 40;
    else if (s.status === 'degraded') sysScore += 20;
    sysScore += Math.min(s.uptime, 100) * 0.4;
    sysScore += Math.max(0, 20 - s.latencyMs / 50);
    score += sysScore;
  }
  return totalSystems > 0 ? Math.round(score / totalSystems) : 0;
}
const maturityScore = calcMaturityScore();
const maturityLevel =
  maturityScore >= 80
    ? 'Excellent'
    : maturityScore >= 60
      ? 'Good'
      : maturityScore >= 40
        ? 'Fair'
        : 'Needs Work';

// Success rate from automation log
const successfulRuns = martech.automationLog.filter((l) => l.status === 'success').length;
const automationSuccessRate =
  martech.automationLog.length > 0 ? (successfulRuns / martech.automationLog.length) * 100 : 0;

// Serialize for client
const systemsData = JSON.stringify(martech.systems);
const automationData = JSON.stringify(martech.automationLog);
---

<DashboardLayout title="Martech Health" activeNav="martech-health">
  <!-- KPI Cards -->
  <section class="grid-kpi">
    <MetricCard
      title="System Health"
      value={`${healthySystems}/${totalSystems}`}
      source={martechResult.source}
      sourceName="Martech"
    />
    <MetricCard
      title="Maturity Score"
      value={`${maturityScore}/100`}
      source={martechResult.source}
      sourceName="Martech"
    />
    <MetricCard
      title="Avg Uptime"
      value={formatPercent(avgUptime)}
      source={martechResult.source}
      sourceName="Martech"
    />
    <MetricCard
      title="Monthly Cost"
      value={formatCurrency(totalCost)}
      source={martechResult.source}
      sourceName="Martech"
    />
    <MetricCard
      title="Avg Latency"
      value={formatLatency(avgLatency)}
      source={martechResult.source}
      sourceName="Martech"
    />
    <MetricCard
      title="Automation Success"
      value={formatPercent(automationSuccessRate)}
      source={martechResult.source}
      sourceName="Martech"
    />
  </section>

  <!-- Maturity Badge -->
  <section class="maturity-section">
    <div class="maturity-card">
      <div class="maturity-header">
        <h3 class="maturity-title">Stack Maturity</h3>
        <span class={`maturity-level maturity-${maturityScore >= 80 ? 'high' : maturityScore >= 60 ? 'mid' : 'low'}`}>
          {maturityLevel}
        </span>
      </div>
      <div class="maturity-bar-bg">
        <div class="maturity-bar-fill" style={`width: ${maturityScore}%`}></div>
      </div>
      <div class="maturity-labels">
        <span>0</span>
        <span>25</span>
        <span>50</span>
        <span>75</span>
        <span>100</span>
      </div>
    </div>
  </section>

  <!-- Charts -->
  <section class="grid-charts">
    <ChartContainer
      title="System Uptime"
      subtitle="Uptime percentage by system"
      source={martechResult.source}
      sourceName="Martech"
      id="martech-uptime-chart"
      height="320px"
    />
    <ChartContainer
      title="Automation Log"
      subtitle="Recent automation execution results"
      source={martechResult.source}
      sourceName="Martech"
      id="martech-automation-chart"
      height="320px"
    />
  </section>

  <!-- Systems Table -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Systems Overview</h3>
      <DataSourceTag source={martechResult.source} name="Martech" />
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>System</th>
            <th>Status</th>
            <th class="num">Uptime</th>
            <th class="num">Latency</th>
            <th class="num">Monthly Cost</th>
            <th>Last Sync</th>
          </tr>
        </thead>
        <tbody>
          {martech.systems.map((s) => (
            <tr>
              <td class="system-name">{s.name}</td>
              <td><StatusBadge status={s.status} /></td>
              <td class="num">{formatPercent(s.uptime)}</td>
              <td class="num">{formatLatency(s.latencyMs)}</td>
              <td class="num">{formatCurrency(s.monthlyCost)}</td>
              <td class="muted">{timeAgo(s.lastSync)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Automation Log Table -->
  <section class="table-section">
    <div class="table-header">
      <h3 class="table-title">Recent Automations</h3>
      <DataSourceTag source={martechResult.source} name="Martech" />
    </div>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Status</th>
            <th class="num">Duration</th>
            <th class="num">Records</th>
            <th>When</th>
          </tr>
        </thead>
        <tbody>
          {martech.automationLog.slice(0, 10).map((log) => (
            <tr>
              <td>{log.name}</td>
              <td>
                <span class={`status-pill status-${log.status}`}>{log.status}</span>
              </td>
              <td class="num">{formatLatency(log.durationMs)}</td>
              <td class="num">{log.recordsProcessed.toLocaleString()}</td>
              <td class="muted">{timeAgo(log.timestamp)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>

<style>
  .grid-kpi { margin-bottom: var(--space-6); }
  .grid-charts { margin-bottom: var(--space-6); }

  .maturity-section { margin-bottom: var(--space-6); }
  .maturity-card {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }
  .maturity-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-3); }
  .maturity-title { font-size: var(--text-sm); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .maturity-level { font-size: var(--text-xs); font-weight: 600; padding: 2px 8px; border-radius: var(--radius-sm); }
  .maturity-high { background: var(--accent-success-dim); color: var(--accent-success); }
  .maturity-mid { background: var(--accent-warning-dim); color: var(--accent-warning); }
  .maturity-low { background: var(--accent-danger-dim); color: var(--accent-danger); }

  .maturity-bar-bg {
    height: 8px;
    background: var(--surface-3);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-bottom: var(--space-1);
  }
  .maturity-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-success));
    border-radius: var(--radius-full);
    transition: width var(--transition-slow);
  }
  .maturity-labels {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--text-muted);
  }

  .table-section {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-6);
  }
  .table-section:last-child { margin-bottom: 0; }
  .table-header { display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--border-default); }
  .table-title { font-size: var(--text-sm); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }
  .table-wrapper { overflow-x: auto; }
  .data-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .data-table th { text-align: left; padding: var(--space-3) var(--space-5); font-size: var(--text-xs); font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid var(--border-default); }
  .data-table td { padding: var(--space-3) var(--space-5); color: var(--text-secondary); border-bottom: 1px solid var(--surface-2); }
  .data-table tr:last-child td { border-bottom: none; }
  .data-table tr:hover td { background: var(--surface-2); }
  .num { text-align: right; font-variant-numeric: tabular-nums; }
  .muted { color: var(--text-muted); font-size: var(--text-xs); }

  .system-name { font-weight: 500; color: var(--text-primary); }

  .status-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: capitalize;
  }
  .status-success { background: var(--accent-success-dim); color: var(--accent-success); }
  .status-failed { background: var(--accent-danger-dim); color: var(--accent-danger); }
  .status-partial { background: var(--accent-warning-dim); color: var(--accent-warning); }
</style>

<script define:vars={{ systemsData, automationData }}>
  window.__martech_systems = JSON.parse(systemsData);
  window.__martech_automation = JSON.parse(automationData);
</script>

<script>
  import { lazyInitCharts } from '../utils/echarts-loader';

  lazyInitCharts([
    {
      id: 'martech-uptime-chart',
      setup: (echarts) => {
        const el = document.getElementById('martech-uptime-chart')!;
        const chart = echarts.init(el, 'dashboard', { devicePixelRatio: Math.max(window.devicePixelRatio, 2) });
        const systems = (window as any).__martech_systems || [];

        chart.setOption({
          tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' }, formatter: (p: any) => `${p[0].name}: ${p[0].value}%` },
          grid: { left: '3%', right: '4%', bottom: '3%', top: '10%', containLabel: true },
          xAxis: { type: 'category', data: systems.map((s: any) => s.name) },
          yAxis: { type: 'value', min: 95, max: 100, axisLabel: { formatter: '{value}%' } },
          series: [{
            type: 'bar',
            data: systems.map((s: any) => ({
              value: s.uptime,
              itemStyle: {
                color: s.uptime >= 99.5 ? '#10b981' : s.uptime >= 99 ? '#f59e0b' : '#ef4444',
                borderRadius: [4, 4, 0, 0],
              },
            })),
            barMaxWidth: 40,
          }],
        });
        window.addEventListener('resize', () => chart.resize());
      },
    },
    {
      id: 'martech-automation-chart',
      setup: (echarts) => {
        const el = document.getElementById('martech-automation-chart')!;
        const chart = echarts.init(el, 'dashboard', { devicePixelRatio: Math.max(window.devicePixelRatio, 2) });
        const logs = (window as any).__martech_automation || [];

        const counts = { success: 0, failed: 0, partial: 0 };
        logs.forEach((l: any) => { counts[l.status as keyof typeof counts]++; });

        chart.setOption({
          tooltip: { trigger: 'item', formatter: '{b}: {c} ({d}%)' },
          series: [{
            type: 'pie',
            radius: ['45%', '70%'],
            center: ['50%', '55%'],
            avoidLabelOverlap: true,
            itemStyle: { borderRadius: 3, borderColor: '#111118', borderWidth: 2 },
            label: { color: '#8892a8', fontSize: 11 },
            labelLayout: { hideOverlap: true },
            data: [
              { value: counts.success, name: 'Success', itemStyle: { color: '#10b981' } },
              { value: counts.failed, name: 'Failed', itemStyle: { color: '#ef4444' } },
              { value: counts.partial, name: 'Partial', itemStyle: { color: '#f59e0b' } },
            ],
          }],
        });
        window.addEventListener('resize', () => chart.resize());
      },
    },
  ]);
</script>
