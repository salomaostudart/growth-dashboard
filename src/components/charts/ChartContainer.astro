---
interface Props {
  title: string;
  subtitle?: string;
  source?: 'live' | 'mock' | 'cached' | 'error';
  sourceName?: string;
  height?: string;
  id: string;
}

const {
  title,
  subtitle,
  source = 'mock',
  sourceName = 'Mock',
  height = '320px',
  id,
} = Astro.props;
---

<div class="chart-container">
  <div class="chart-header">
    <div class="chart-title-group">
      <h3 class="chart-title">{title}</h3>
      {subtitle && <p class="chart-subtitle">{subtitle}</p>}
    </div>
    <div class="chart-actions">
      <div class:list={['source-tag', `source-${source}`]}>
        <span class="source-dot"></span>
        <span>{sourceName}</span>
      </div>
    </div>
  </div>
  <div class="chart-body" id={id} style={`height: ${height}`}>
    <slot />
  </div>
</div>

<style>
  .chart-container {
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-fast);
  }

  .chart-container:hover {
    border-color: var(--border-hover);
  }

  .chart-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-default);
  }

  .chart-title {
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .chart-subtitle {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: 2px;
  }

  .chart-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .source-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: var(--radius-full);
    font-weight: 500;
  }

  .source-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  .source-live { background: var(--accent-success-dim); color: var(--accent-success); }
  .source-live .source-dot { background: var(--accent-success); }
  .source-mock { background: var(--surface-3); color: var(--text-muted); }
  .source-mock .source-dot { background: var(--text-muted); }
  .source-cached { background: var(--accent-warning-dim); color: var(--accent-warning); }
  .source-cached .source-dot { background: var(--accent-warning); }
  .source-error { background: var(--accent-danger-dim); color: var(--accent-danger); }
  .source-error .source-dot { background: var(--accent-danger); }

  .chart-body {
    padding: var(--space-4);
  }
</style>
