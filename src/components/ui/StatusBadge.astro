---
interface Props {
  status: 'healthy' | 'degraded' | 'down' | 'unknown';
  label?: string;
}

const { status, label } = Astro.props;

const statusConfig = {
  healthy: { color: 'var(--accent-success)', text: label || 'Healthy' },
  degraded: { color: 'var(--accent-warning)', text: label || 'Degraded' },
  down: { color: 'var(--accent-danger)', text: label || 'Down' },
  unknown: { color: 'var(--text-muted)', text: label || 'Unknown' },
};

const config = statusConfig[status];
---

<span class="status-badge" style={`--badge-color: ${config.color}`}>
  <span class="status-pulse"></span>
  <span>{config.text}</span>
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--badge-color);
  }

  .status-pulse {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--badge-color);
  }

  .status-pulse::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 50%;
    border: 1px solid var(--badge-color);
    opacity: 0.4;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0; transform: scale(1.5); }
  }
</style>
