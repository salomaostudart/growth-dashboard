---
/**
 * AuthGate — redirects to /login if no valid session.
 * When Supabase is not configured (demo mode), does nothing.
 */
---

<script>
  import { supabase, isConfigured } from '../../lib/supabase';
  import { isEmailAllowed, redirectToLogin } from '../../lib/auth';

  if (isConfigured && supabase) {
    const { data: { session } } = await supabase.auth.getSession();

    if (!session) {
      redirectToLogin();
    } else if (!isEmailAllowed(session.user.email || '')) {
      await supabase.auth.signOut();
      redirectToLogin();
    }

    supabase.auth.onAuthStateChange((event) => {
      if (event === 'SIGNED_OUT') {
        redirectToLogin();
      }
    });
  }
</script>
