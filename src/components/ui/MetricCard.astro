---
interface Props {
  title: string;
  value: string;
  delta?: number;
  deltaLabel?: string;
  source?: 'live' | 'mock' | 'cached' | 'error';
  sourceName?: string;
  sparklineData?: number[];
  tooltip?: string;
}

import DataSourceTag from './DataSourceTag.astro';

const {
  title,
  value,
  delta,
  deltaLabel = 'vs prev period',
  source = 'mock',
  sourceName = 'Mock',
  sparklineData = [],
  tooltip,
} = Astro.props;

const deltaType = delta === undefined ? 'neutral' : delta > 0 ? 'positive' : delta < 0 ? 'negative' : 'neutral';
const deltaFormatted = delta !== undefined ? `${delta > 0 ? '+' : ''}${delta.toFixed(1)}%` : '';

// Generate sparkline SVG path
function generateSparklinePath(data: number[]): string {
  if (data.length < 2) return '';
  const min = Math.min(...data);
  const max = Math.max(...data);
  const range = max - min || 1;
  const width = 120;
  const height = 32;
  const step = width / (data.length - 1);
  return data.map((val, i) => {
    const x = i * step;
    const y = height - ((val - min) / range) * height;
    return `${i === 0 ? 'M' : 'L'}${x},${y}`;
  }).join(' ');
}

const sparklinePath = generateSparklinePath(sparklineData);
---

<div class="metric-card">
  {sparklineData.length > 0 && (
    <svg class="sparkline" viewBox="0 0 120 32" preserveAspectRatio="none" aria-hidden="true" focusable="false">
      <path d={sparklinePath} fill="none" stroke="currentColor" stroke-width="1.5" />
    </svg>
  )}
  <div class="metric-header">
    <span class="metric-title">
      {title}
      {tooltip && (
        <span class="tooltip-trigger" tabindex="0" data-tooltip={tooltip}>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><text x="8" y="12" text-anchor="middle" fill="currentColor" font-size="10" font-weight="600">?</text></svg>
          <span class="tooltip-content">{tooltip}</span>
        </span>
      )}
    </span>
    <DataSourceTag source={source} name={sourceName} />
  </div>
  <div class="metric-value">{value}</div>
  {delta !== undefined && (
    <div class={`metric-delta delta-${deltaType}`}>
      <span class="delta-arrow">{deltaType === 'positive' ? '\u2191' : deltaType === 'negative' ? '\u2193' : '\u2192'}</span>
      <span>{deltaFormatted}</span>
      <span class="delta-label">{deltaLabel}</span>
    </div>
  )}
</div>

<style>
  .metric-card {
    position: relative;
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    overflow: hidden;
    transition: all var(--transition-fast);
  }

  .metric-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-glow);
  }

  .sparkline {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 50%;
    height: 40px;
    color: var(--accent-primary);
    opacity: 0.15;
  }

  .metric-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .metric-title {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .metric-value {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .metric-delta {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .delta-positive { color: var(--accent-success); }
  .delta-negative { color: var(--accent-danger); }
  .delta-neutral { color: var(--text-muted); }

  .delta-label {
    color: var(--text-muted);
    font-weight: 400;
  }

  .tooltip-trigger {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin-left: 4px;
    color: var(--text-muted);
    cursor: help;
    vertical-align: middle;
  }

  .tooltip-content {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(max(-50%, calc(-100vw + 240px)));
    background: var(--surface-3);
    border: 1px solid var(--border-hover);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-primary);
    text-transform: none;
    letter-spacing: normal;
    white-space: normal;
    width: 220px;
    max-width: calc(100vw - 2rem);
    line-height: 1.5;
    z-index: 10;
    box-shadow: var(--shadow-md);
  }

  .tooltip-trigger:hover .tooltip-content,
  .tooltip-trigger:focus .tooltip-content,
  .tooltip-trigger:focus-within .tooltip-content { display: block; }
</style>
