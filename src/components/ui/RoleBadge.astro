---
/**
 * RoleBadge — displays current user role in the sidebar.
 * Client-side: fetches role from Supabase profile.
 * Hidden when Supabase is not configured.
 */
---

<div class="role-badge-container" id="role-badge" style="display: none;">
  <span class="role-dot" id="role-dot"></span>
  <span class="role-email" id="role-email"></span>
  <span class="role-label" id="role-label"></span>
  <button class="role-logout" id="role-logout" title="Sign out">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
      <polyline points="16 17 21 12 16 7" />
      <line x1="21" y1="12" x2="9" y2="12" />
    </svg>
  </button>
</div>

<style>
  .role-badge-container {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--surface-2);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
  }

  .role-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .role-email {
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }

  .role-label {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .role-logout {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 2px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .role-logout:hover { color: var(--accent-danger); }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SUPABASE_URL = (import.meta as any).env?.PUBLIC_SUPABASE_URL || '';
  const SUPABASE_ANON_KEY = (import.meta as any).env?.PUBLIC_SUPABASE_ANON_KEY || '';

  if (SUPABASE_URL && SUPABASE_ANON_KEY) {
    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    const { data: { session } } = await supabase.auth.getSession();

    if (session) {
      const { data: profile } = await supabase
        .from('profiles')
        .select('role, email')
        .eq('id', session.user.id)
        .single();

      if (profile) {
        const badge = document.getElementById('role-badge')!;
        const dot = document.getElementById('role-dot')!;
        const email = document.getElementById('role-email')!;
        const label = document.getElementById('role-label')!;

        const colors: Record<string, string> = {
          admin: '#818cf8', analyst: '#10b981', viewer: '#94a3b8',
        };

        dot.style.background = colors[profile.role] || '#94a3b8';
        label.style.color = colors[profile.role] || '#94a3b8';
        email.textContent = profile.email.split('@')[0];
        label.textContent = profile.role;
        badge.style.display = 'flex';

        // Logout
        document.getElementById('role-logout')?.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.reload();
        });
      }
    }
  }
</script>
