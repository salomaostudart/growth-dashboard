# Growth Dashboard — Environment Variables
# Copy this file to .env and fill in values as needed.
# IMPORTANT: Never store service account keys inside the project directory.

# Google Analytics 4
# Set to "true" to use real GA4 data instead of mock
GA4_ENABLED=false
GA4_PROPERTY_ID=
# Path to service account JSON — must be OUTSIDE the project directory
# Example: ~/.credentials/growth-dashboard-sa.json
GA4_SERVICE_ACCOUNT_JSON=

# Google Search Console
GSC_ENABLED=false
GSC_SITE_URL=

# Email Marketing (Mailchimp)
EMAIL_ENABLED=false
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# Social Media APIs
SOCIAL_ENABLED=false
LINKEDIN_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=

# CRM (HubSpot)
CRM_ENABLED=false
HUBSPOT_API_KEY=

# Martech Health
MARTECH_ENABLED=false

# Supabase (Auth + RBAC + Chat)
# Access control: invite-only via Supabase dashboard (Authentication > Users > Invite)
# Create project at dashboard.supabase.com, copy URL and anon key
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Claude API (for AI Chat — Bloco 4)
# Used by Supabase Edge Function, not client-side
CLAUDE_API_KEY=
