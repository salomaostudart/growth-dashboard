# Growth Dashboard — Environment Variables
# Copy this file to .env and fill in values as needed.

# Google Analytics 4
# Set to "true" to use real GA4 data instead of mock
GA4_ENABLED=false
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=

# Google Search Console
GSC_ENABLED=false
GSC_SITE_URL=

# Email Marketing (Mailchimp)
EMAIL_ENABLED=false
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# Social Media APIs
SOCIAL_ENABLED=false
LINKEDIN_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=

# CRM (HubSpot)
CRM_ENABLED=false
HUBSPOT_API_KEY=

# Martech Health
MARTECH_ENABLED=false
